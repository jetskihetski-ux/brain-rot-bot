# Reddit API — create app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USER_AGENT=brain-rot-bot/1.0 by u/yourusername

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_key

# YouTube — download client_secrets.json from Google Cloud Console
# (Enable YouTube Data API v3, create OAuth 2.0 credentials)
YOUTUBE_CLIENT_SECRETS=client_secrets.json

# TikTok Content Posting API (optional — set to "skip" to disable)
# Apply at https://developers.tiktok.com
TIKTOK_SESSION_ID=skip
